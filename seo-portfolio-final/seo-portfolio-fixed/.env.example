# ════════════════════════════════════════════════
# SEO Portfolio — Environment Variables
# Copy this file to .env.local and fill in values
# ════════════════════════════════════════════════

# Formspree — Contact form email delivery
# Get from: formspree.io → New Form → copy Form ID
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id

# WhatsApp number (country code + number, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567

# Calendly or Google Calendar booking URL
NEXT_PUBLIC_CALENDAR_URL=https://calendly.com/your-username/seo-strategy-call

# Your domain (for sitemap and OG tags)
NEXT_PUBLIC_SITE_URL=https://seoexpert.pk
